# ============================================================================
# STF AI Diagnosis Platform - PolyU Server Environment Configuration
# Author: Li-Ta Hsu
# Date: March 2026
# ============================================================================
# Copy to .env and fill in actual values before starting services.
# NEVER commit the real .env file to version control.
# ============================================================================

# ----------------------------------------------------------------------------
# Network Configuration (PolyU Server)
# ----------------------------------------------------------------------------
# Services bind to localhost; only Nginx is exposed externally on port 80.
BIND_HOST=127.0.0.1
NGINX_PORT=80

# ----------------------------------------------------------------------------
# Postgres Configuration
# ----------------------------------------------------------------------------
POSTGRES_VERSION=0.7.4-pg15
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=stf_diagnosis
POSTGRES_USER=stf_user
POSTGRES_PASSWORD=CHANGE_ME_USE_openssl_rand_hex_24

APP_DB_NAME=stf_diagnosis
APP_DB_USER=stf_app_user
APP_DB_PASSWORD=CHANGE_ME_USE_openssl_rand_hex_24

# ----------------------------------------------------------------------------
# Ollama Configuration (2x RTX 6000 Ada, 92 GB VRAM total)
# ----------------------------------------------------------------------------
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_DEFAULT_MODEL=qwen3.5:9b
EMBEDDING_MODEL=nomic-embed-text
VISION_MODEL=llava

# ----------------------------------------------------------------------------
# Diagnostic API Configuration
# ----------------------------------------------------------------------------
DIAGNOSTIC_API_HOST=diagnostic-api
DIAGNOSTIC_API_PORT=8000
DIAGNOSTIC_API_VERSION=0.1.0
DIAGNOSTIC_API_LOG_LEVEL=INFO
DIAGNOSTIC_API_LOG_FORMAT=json

# OBD UI
OBD_UI_PORT=3001
OBD_UI_VERSION=0.1.0

# ----------------------------------------------------------------------------
# Authentication (JWT)
# ----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# ----------------------------------------------------------------------------
# Premium LLM Configuration - OpenRouter (server has internet access)
#
# REGIONAL RESTRICTIONS (Hong Kong - as of March 2026)
# Some providers block API access from HK. The platform auto-probes at
# startup and hides blocked models, and the diagnosis endpoint falls back
# to the next available model on 403.
#
# Known BLOCKED from HK:
#   anthropic/claude-opus-4.6, anthropic/claude-sonnet-4.6
#   openai/gpt-5.2, openai/gpt-5-mini
#   google/gemini-3.1-pro-preview, google/gemini-3-flash-preview
#
# Known ACCESSIBLE from HK:
#   deepseek/deepseek-v3.2, deepseek/deepseek-chat
#   qwen/qwen3.5-plus-02-15, qwen/qwen3.5-flash-02-23
#   minimax/minimax-m2.7, minimax/minimax-m2.5
#   z-ai/glm-5, z-ai/glm-4.7
#   moonshotai/kimi-k2.5, moonshotai/kimi-k2
# ----------------------------------------------------------------------------
PREMIUM_LLM_ENABLED=true
PREMIUM_LLM_API_KEY=CHANGE_ME_OPENROUTER_API_KEY
PREMIUM_LLM_BASE_URL=https://openrouter.ai/api/v1
PREMIUM_LLM_MODEL=deepseek/deepseek-v3.2
PREMIUM_LLM_CURATED_MODELS=anthropic/claude-opus-4.6,anthropic/claude-sonnet-4.6,google/gemini-3.1-pro-preview,google/gemini-3-flash-preview,openai/gpt-5.2,openai/gpt-5-mini,deepseek/deepseek-v3.2,deepseek/deepseek-chat,qwen/qwen3.5-plus-02-15,qwen/qwen3.5-flash-02-23,minimax/minimax-m2.7,minimax/minimax-m2.5,z-ai/glm-5,z-ai/glm-4.7,moonshotai/kimi-k2.5,moonshotai/kimi-k2
